{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
    <div class="container mt-5">
        {{ form_start(form, { "attr": { "id": "forgot-password-form", "autocomplete": "on" } }) }}
        {{ form_row(form.email) }}
        <button type="submit" class="btn btn-primary">Envoyer</button>
        {{ form_end(form) }}
        <div id="result" class="mt-3"></div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('security') }}
{% endblock %}
